<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E21">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SPICA"
        android:textColor="#4D9DE0"
        android:textSize="52sp"
        android:textStyle="bold"
        android:letterSpacing="0.3"
        android:layout_marginTop="60dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/subtitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="EMERGENCY SAFETY SYSTEM"
        android:textColor="#5C6B7A"
        android:textSize="12sp"
        android:letterSpacing="0.25"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/titleText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="● SYSTEM READY"
        android:textColor="#4CAF50"
        android:textSize="14sp"
        android:letterSpacing="0.1"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toBottomOf="@id/subtitleText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/startListeningBtn"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="START LISTENING"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:background="@drawable/btn_primary"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/stopListeningBtn"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="STOP LISTENING"
            android:textColor="#8899AA"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:background="@drawable/btn_secondary"
            android:layout_marginBottom="40dp" />

        <Button
            android:id="@+id/sosBtn"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:text="SOS"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="0.3"
            android:background="@drawable/btn_sos" />

    </LinearLayout>

    <Button
        android:id="@+id/contactsBtn"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="MANAGE CONTACTS"
        android:textColor="#4D9DE0"
        android:textSize="14sp"
        android:letterSpacing="0.1"
        android:background="@drawable/btn_outline"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:layout_marginBottom="30dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
