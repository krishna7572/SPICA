<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E21">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EDIT COMMANDS"
            android:textColor="#4D9DE0"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Separate multiple commands with comma (,)"
            android:textColor="#5C6B7A"
            android:textSize="13sp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎙️  START AUDIO RECORDING"
            android:textColor="#4D9DE0"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/startAudioInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textColorHint="#5C6B7A"
            android:background="@drawable/btn_secondary"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_marginBottom="20dp"
            android:minLines="2"
            android:inputType="textMultiLine" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏹️  STOP AUDIO RECORDING"
            android:textColor="#4D9DE0"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/stopAudioInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textColorHint="#5C6B7A"
            android:background="@drawable/btn_secondary"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_marginBottom="20dp"
            android:minLines="2"
            android:inputType="textMultiLine" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📹  START VIDEO RECORDING"
            android:textColor="#4D9DE0"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/startVideoInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textColorHint="#5C6B7A"
            android:background="@drawable/btn_secondary"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_marginBottom="20dp"
            android:minLines="2"
            android:inputType="textMultiLine" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏹️  STOP VIDEO RECORDING"
            android:textColor="#4D9DE0"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/stopVideoInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textColorHint="#5C6B7A"
            android:background="@drawable/btn_secondary"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_marginBottom="20dp"
            android:minLines="2"
            android:inputType="textMultiLine" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🆘  EMERGENCY / SOS"
            android:textColor="#E63946"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/emergencyInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textColorHint="#5C6B7A"
            android:background="@drawable/btn_secondary"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_marginBottom="28dp"
            android:minLines="2"
            android:inputType="textMultiLine" />

        <Button
            android:id="@+id/saveCommandsBtn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="SAVE COMMANDS"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:background="@drawable/btn_primary"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/resetCommandsBtn"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="RESET TO DEFAULT"
            android:textColor="#4D9DE0"
            android:textSize="14sp"
            android:background="@drawable/btn_outline"
            android:layout_marginBottom="32dp" />

    </LinearLayout>
</ScrollView>
