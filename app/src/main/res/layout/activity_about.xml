<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E21">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SPICA"
            android:textColor="#4D9DE0"
            android:textSize="40sp"
            android:textStyle="bold"
            android:letterSpacing="0.3"
            android:layout_gravity="center"
            android:layout_marginTop="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Emergency Safety System"
            android:textColor="#5C6B7A"
            android:textSize="14sp"
            android:layout_gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Version 1.0"
            android:textColor="#4D9DE0"
            android:textSize="12sp"
            android:layout_gravity="center"
            android:layout_marginBottom="32dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1E2A3A"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ABOUT"
            android:textColor="#4D9DE0"
            android:textSize="13sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SPICA is a personal emergency safety app designed to protect you in dangerous situations. With voice commands, one-tap SOS, and automatic alerts, help is always one command away."
            android:textColor="#AABBCC"
            android:textSize="15sp"
            android:lineSpacingMultiplier="1.5"
            android:layout_marginBottom="28dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KEY FEATURES"
            android:textColor="#4D9DE0"
            android:textSize="13sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎤  Voice Commands (English + Hindi)\n\n🎙️  Audio Recording\n\n📹  Background Video Recording\n\n🆘  One-tap SOS with auto SMS\n\n📍  Live Location sharing\n\n👥  Emergency Contacts\n\n📴  Works Offline (no internet needed)"
            android:textColor="#AABBCC"
            android:textSize="15sp"
            android:lineSpacingMultiplier="1.8"
            android:layout_marginBottom="28dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1E2A3A"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HOW TO USE"
            android:textColor="#4D9DE0"
            android:textSize="13sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1. Add emergency contacts (like family)\n\n2. Tap START LISTENING\n\n3. Say commands like:\n   • 'start recording'\n   • 'start video'\n   • 'emergency'\n\n4. In danger — press SOS button\n   App will record + send SMS automatically"
            android:textColor="#AABBCC"
            android:textSize="15sp"
            android:lineSpacingMultiplier="1.6"
            android:layout_marginBottom="32dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Made with ❤️ for your safety"
            android:textColor="#5C6B7A"
            android:textSize="13sp"
            android:layout_gravity="center"
            android:layout_marginBottom="32dp" />

    </LinearLayout>
</ScrollView>
